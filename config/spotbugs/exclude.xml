<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude any classes containing 'Generated' in their names -->
    <Match>
        <Class name="~.*Generated.*"/>
    </Match>
    <!-- Exclude any classes in a package named 'generated' -->
    <Match>
        <Class name="~.*\.generated\..*"/>
    </Match>
    <!-- Exclude VertxProvider from EI_EXPOSE_REP and EI_EXPOSE_REP2 -->
    <Match>
        <Class name="org.larpconnect.events.VertxProvider"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
