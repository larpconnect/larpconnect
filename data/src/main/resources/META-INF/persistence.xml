<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="larpconnect">
        <provider>org.hibernate.reactive.provider.ReactivePersistenceProvider</provider>

        <class>com.larpconnect.njall.data.entity.Entity</class>
        <class>com.larpconnect.njall.data.entity.Actor</class>
        <class>com.larpconnect.njall.data.entity.ActorEndpoint</class>
        <class>com.larpconnect.njall.data.entity.Campaign</class>
        <class>com.larpconnect.njall.data.entity.LarpCharacter</class>
        <class>com.larpconnect.njall.data.entity.CharacterInstance</class>
        <class>com.larpconnect.njall.data.entity.Collection</class>
        <class>com.larpconnect.njall.data.entity.CollectionItem</class>
        <class>com.larpconnect.njall.data.entity.ContactInfo</class>
        <class>com.larpconnect.njall.data.entity.Game</class>
        <class>com.larpconnect.njall.data.entity.Individual</class>
        <class>com.larpconnect.njall.data.entity.Location</class>
        <class>com.larpconnect.njall.data.entity.Role</class>
        <class>com.larpconnect.njall.data.entity.ServerMetadata</class>
        <class>com.larpconnect.njall.data.entity.Studio</class>
        <class>com.larpconnect.njall.data.entity.StudioRole</class>
        <class>com.larpconnect.njall.data.entity.LarpSystem</class>
        <class>com.larpconnect.njall.data.entity.User</class>

        <properties>
            <!-- Vert.x PostgreSQL connection pool properties should be provided dynamically or via configuration -->
        </properties>
    </persistence-unit>
</persistence>
